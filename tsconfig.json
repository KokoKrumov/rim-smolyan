{
  // TypeScript 6.0: Updated defaults (strict on by default, DOM includes dom.iterable,
  // allowSyntheticDefaultImports always-on, decorators options removed as unused).
  // Build optimizations for ES2022: modern class fields, module detection,
  // incremental compilation, and lib definitions for better performance.
  // TypeScript 6.0: Optimized for IDE/type-checking, Vite handles build-specific optimizations
  "compilerOptions": {
    // "allowJs": false, // Default value - removed for brevity
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    // Ensures each file can be compiled independently - required for bundlers like Vite
    // for better performance
    "isolatedModules": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true, // Let Vite handle emission for better build performance
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    // "noLib": false, // Default value - removed for brevity
    // "noResolve": false, // Default value - removed for brevity
    // "noUnusedLocals": false, // Default value - removed for brevity
    "noUnusedParameters": true,
    "preserveConstEnums": true,
    "sourceMap": true,
    "strict": true,
    "stripInternal": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "useDefineForClassFields": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo",
    "assumeChangesOnlyAffectDirectDependencies": true,
    "preserveSymlinks": true
  },
  "exclude": [
    "node_modules",
  ]
}
